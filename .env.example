DISCORD_TOKEN=your_discord_token_here
MEDIA_PATH=/home/youruser/path/to/your/content
# Optional: prefix for organized file names (default: none).
# The prefix is normalised: leading/trailing underscores are trimmed,
# runs of underscores are collapsed, whitespace becomes underscores, and
# invalid filename characters are stripped. A single "_" separator is
# added automatically between the prefix and the UUID.
# MEDIA_NAME_PREFIX=grub
# Optional: your host user/group IDs to avoid permission issues
# UID=1000
# GID=1000
