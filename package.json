{
  "name": "uploader-grub",
  "version": "1.3.3",
  "type": "module",
  "packageManager": "pnpm@10.24.0",
  "scripts": {
    "start": "node dist/index.js",
    "build": "rm -rf dist && tsc && cp src/logo.webp dist/logo.webp",
    "dev": "tsx watch src/index.ts",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "prepare": "husky"
  },
  "lint-staged": {
    "src/**/*.ts": [
      "prettier --write",
      "eslint --fix"
    ]
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "@discordjs/rest": "^2.6.2",
    "chokidar": "^5.0.0",
    "discord.js": "^14.21.0",
    "dotenv": "^17.2.1",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.5",
    "@types/node": "^26.1.1",
    "eslint": "^9.39.5",
    "eslint-plugin-import": "^2.32.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "prettier": "^3.9.5",
    "tsx": "^4.23.1",
    "typescript": "5.9.3",
    "typescript-eslint": "^8.64.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp"
    ]
  }
}
